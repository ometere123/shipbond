# ─── GenLayer / Bradbury ────────────────────────────────────────────────────
# Single RPC — handles both intelligent contract calls and standard ETH methods
NEXT_PUBLIC_GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
NEXT_PUBLIC_CHAIN_ID=4221

# Chain RPC — for wagmi/MetaMask network config
NEXT_PUBLIC_GENLAYER_CHAIN_RPC=https://rpc.testnet-chain.genlayer.com

# Explorer URLs (two separate explorers per Bradbury docs)
NEXT_PUBLIC_BRADBURY_EXPLORER=https://explorer-bradbury.genlayer.com
NEXT_PUBLIC_CHAIN_EXPLORER=https://explorer.testnet-chain.genlayer.com
NEXT_PUBLIC_FAUCET_URL=https://testnet-faucet.genlayer.foundation

# Global ShipBond protocol contract on Bradbury (one contract, all milestones)
NEXT_PUBLIC_SHIPBOND_PROTOCOL_ADDRESS=0xfb305e9011C58ebc1303795693026769E955e6B7
# Server-side alias (same value)
SHIPBOND_PROTOCOL_ADDRESS=0xfb305e9011C58ebc1303795693026769E955e6B7

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY — never expose to browser, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# ─── Session ─────────────────────────────────────────────────────────────────
# 32+ random bytes — generate with: openssl rand -base64 32
SESSION_SECRET=
SESSION_COOKIE_NAME=__shipbond_session
# Seconds — 7 days
SESSION_MAX_AGE=604800
